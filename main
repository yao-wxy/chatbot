import json

from emotion_score import emotion_scoring
from memory import memory,short_term_memory
import os
from conversation import conversation
from personal_picture import personal_picture
from safe_json_loads import safe_json_loads

def main():
    API_KEY = "sk-08a85c5577e94d3bbf38f98adb72a842"
    BASE_URL = "https://api.deepseek.com"
    MODEL_NAME = "deepseek-chat"
    max_count=5
    clear_file=False
    debug=False

    if clear_file:
        open("emotion_score.json", "w", encoding="utf-8").close()
        open("memory.json", "w", encoding="utf-8").close()
        open("count.json", "w", encoding="utf-8").close()

    open("memory.json", "w", encoding="utf-8").close()

    while True:
        user_input = input("用户：")

        if debug:
            user_input = '你好。'

        if user_input=="结束":
            break

        result = memory(user_input, API_KEY, MODEL_NAME, BASE_URL, max_count)
        final_emotion_score=emotion_scoring(max_count)

        # 临时对话窗口
        temporary_memory = short_term_memory(max_count,final_emotion_score)

        preferred_information = personal_picture(API_KEY,BASE_URL,MODEL_NAME,user_input)

        # 历史和情绪分数打完了。现在进入关键回答环节。
        response=conversation(API_KEY,BASE_URL,MODEL_NAME,user_input,preferred_information,temporary_memory)

        print('助手：',response)



if __name__=="__main__":
    main()




